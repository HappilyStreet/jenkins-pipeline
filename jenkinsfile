pipeline {
    agent any
    environment {
        serviceDir = '../MyToDoService'  // путь к клонированному репозиторию с микросервисом
        imageTag = "mytodo-${env.BUILD_NUMBER}"  // общий тег для всех стадий
    }
    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        stage('Build Stage'){
            steps{
                script{
                    def buildScript = load 'vars/build.groovy'
                    buildScript.buildStage()
                }
            }
        }
        // stage('Push docker image') {
