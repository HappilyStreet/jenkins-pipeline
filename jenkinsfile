def serviceDir = '../my-todo-service' // путь до репы микросевиса
def imageTag = env.BUILD_NUMBER // номеруем сборку

pipeline {
    agent any
    stages {
        stage('Build Stage'){
            steps{
                load 'vars.build-groovy'
            }
        }
        stage('Push docker image') {
            steps {
                load 'vars.push-groovy'
            }
        }
        stage('Push docker image') {
            steps {
                load 'vars.deploy-groovy'
            }
        }
    }
}
