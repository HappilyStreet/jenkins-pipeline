pipeline {
    agent any
    environment {
        serviceDir = '../app'  // путь к клонированному репозиторию с микросервисом
        imageTag = "mytodo-${env.BUILD_NUMBER}"  // общий тег для всех стадий
    }
    triggers {
        githubPush()
    }
    stages {
        stage('Packages and Tests') {
            when {
                branch 'main'
            }
            steps {
                script{
                    def packagesScript = load 'vars/packages.groovy'
                    packagesScript.packagesStage()
                }
            }
        }
        stage('Build and push') {
            when {
                branch 'main'
            }
            steps {
                script {
                    def buildScript = load 'vars/build.groovy'
                    buildScript.buildStage()
                }
            }
        }
        stage('Deploy') {
            when {
                anyOf {
                    branch 'main'
                    expression {params.BUILD == 'install'}
                }
            }
            steps {
                script {
                    def deployScript = load 'vars/deploy.groovy'
                    deployScript.deployStage
                }
            }
        }
        stage('Run tests after deploy') {
            when {
                anyOf {
                    branch 'main'
                    expression {params.BUILD == 'install'}
                }
            }
            steps {
                script {
                    def testsScript = load 'var/tests.groovy'
                    testScript.testStage
                }
            }
        }
        stage('Delete service') {
            when {
                expression { params.BUILD == 'delete' }
            }
            steps {
                script {
                    def deleteScript = load 'vars/delete.groovy'
                    deleteScript.deleteStage()
                }
            }
        }
        stage('Clean old files') {
            steps {
                script {
                    cleanWs()
                }
            }
        }
    }
}