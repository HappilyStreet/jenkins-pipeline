pipeline {
    agent any
    environment {
        serviceDir = '../app'  // путь к клонированному репозиторию с микросервисом
        imageTag = "mytodo-${env.BUILD_NUMBER}"  // общий тег для всех стадий
    }
    stages {
        stage('Build Stage'){
            steps{
                script{
                    if(params.BUILD == 'delete') {
                        echo "skipping install stage"
                    } else {
                        def buildScript = load 'vars/build.groovy'
                        buildScript.buildStage()
                        
                        def changeDetected = buildScript.buildStage()

                        echo "Change detected? ${changeDetected}"
                    }
                }
            }
        }
        stage('Push docker image') {
            steps {
                script{
                    if(params.BUILD == 'delete') {
                        echo "skipping Push stage"
                    }else if(changeDetected) {
                        def pushScript = load 'vars/push.groovy'
                        pushScript.pushStage()
                    } else {
                        echo "No changes...skipping push stage"
                    }
                }
            }
        }
        stage('Deploy docker via helm') {
            steps {
                script{
                    if(params.BUILD == 'delete') {
                        echo "skipping Deploy stage"
                    }else{
                        def deployScript = load 'vars/deploy.groovy'
                        deployScript.deployStage()                       
                    }
 
                }
            }
        }
        stage('Post-Deploy Tests') {
            steps {
                script {
                    if(params.BUILD == 'delete') {
                        echo "skipping Test stage"
                    }else{
                        def postTest = load 'vars/check.groovy'
                        postTest.testStage()
                    }

                }
            }
        }
        stage('Delete Serivice') {
            steps {
                script {
                    if(params.BUILD == 'delete') {
                        def deleteScript = load 'vars/delete.groovy'
                        deleteScript.deleteStage()
                    } else{
                        echo "No need to delete"
                    }
                }
            }
        }
        stage('Clean old files') {
            steps {
                script {
                    deleteDir ()
                }
            }
        }
    }
}
